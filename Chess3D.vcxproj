  </ImportGroup>

  <PropertyGroup Label="UserMacros" />

  <!-- Forward-slash paths for C++ string literals (avoids \b \r \s escape issues) -->
  <PropertyGroup>
    <Chess3DProjFwd>$([System.String]::Copy('$(ProjectDir)').Replace('\', '/'))</Chess3DProjFwd>
  </PropertyGroup>

  <!-- Output directories -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <OutDir>$(ProjectDir)bin\$(Configuration)\</OutDir>
